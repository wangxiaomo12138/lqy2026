{
  "agent_id": "retry-assistant",
  "name": "在线重试助手（单次循环）",
  "description": "为业务 Agent 提供「执行→检查→记录→重试」能力。通常被总 Agent 引用，或作为业务 Agent 的前置 Skill 包。",
  "version": "1.0.0",

  "mcp_servers": [
    {
      "name": "check-mcp",
      "url": "http://YOUR_HOST:8200/mcp",
      "tools": ["check.evaluate"]
    },
    {
      "name": "run-log-mcp",
      "url": "http://YOUR_HOST:8300/mcp",
      "tools": ["run.log", "run.stats"]
    }
  ],

  "skills": [
    {
      "skill_id": "auto-retry-replan",
      "ref": "skills/auto-retry-replan/SKILL.md"
    }
  ],

  "workflows": [
    {
      "workflow_id": "wf_retry_wrapper",
      "ref": "integrations/workflows/wf_retry_wrapper.json"
    }
  ],

  "usage": {
    "how_others_use": "总 Agent 引用本 Agent；或把 auto-retry-replan Skill + 两个 MCP 复制到业务 Agent"
  }
}
